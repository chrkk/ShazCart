<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_list_item"
    android:padding="12dp"
    android:layout_marginBottom="6dp">

    <!-- Icon — mirrors imageview_profile_pic from ListViewPrac item row -->
    <ImageView
        android:id="@+id/imageview_row_icon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:scaleType="fitCenter"
        android:src="@drawable/shazcartgreenlogo2"
        android:contentDescription="Item icon"/>

    <!-- Text column — mirrors textview_fullname from ListViewPrac item row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="center_vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/textview_row_primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#111827"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/textview_row_secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#6B7280"
            android:textSize="12sp"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

</LinearLayout>
