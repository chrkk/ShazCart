<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutDashboardPage"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Header — unchanged from original ShazCart design -->
    <RelativeLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:padding="16dp"
        android:background="@drawable/bg_gradient_green">

        <TextView
            android:id="@+id/textviewGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Good afternoon, S 👋"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_alignParentStart="true"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/textviewNotification"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔔 3"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/textviewGroupMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Group Mode — Sunset Boarding House"
            android:textColor="#BBF7D0"
            android:textSize="14sp"
            android:layout_below="@id/textviewGreeting"
            android:layout_marginTop="12dp"/>
    </RelativeLayout>

    <!-- Summary Boxes — unchanged from original ShazCart design -->
    <LinearLayout
        android:id="@+id/layoutSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3"
        android:padding="16dp">

        <TextView
            android:id="@+id/textviewTotalItems"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="6 Total Items"
            android:textColor="#374151"
            android:textSize="14sp"
            android:background="@drawable/bg_card"
            android:padding="12dp"/>

        <TextView
            android:id="@+id/textviewPendingItems"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="4 Pending"
            android:textColor="#374151"
            android:textSize="14sp"
            android:background="@drawable/bg_card"
            android:padding="12dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/textviewTotalSpent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="₱1,800 Total Spent"
            android:textColor="#374151"
            android:textSize="14sp"
            android:background="@drawable/bg_card"
            android:padding="12dp"/>

        <ListView
            android:id="@+id/listviewHousemates"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:clipToPadding="false"
            android:divider="@null"
            android:dividerHeight="0dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />
    </LinearLayout>

    <!-- Scrollable body — needed because two ListViews inside a LinearLayout require
         each ListView to have a fixed height; ScrollView wraps both sections -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ═══════════════════════════════════════════
                 HOUSEMATES SECTION
                 Mirrors the ListView + Add/Remove pattern from ListViewPrac activity_setting.xml
                 ═══════════════════════════════════════════ -->

            <TextView
                android:id="@+id/textviewHousematesTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Housemates"
                android:textColor="#059669"
                android:textSize="16sp"
                android:textStyle="bold"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"/>

            <!-- Add Item button — mirrors button_add_item from ListViewPrac activity_setting.xml -->
            <Button
                android:id="@+id/buttonAddHousemate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="8dp"
                android:backgroundTint="#059669"
                android:text="＋ Add Housemate"
                android:textColor="#FFFFFF"/>

            <!-- ListView for Housemates — mirrors listview from ListViewPrac activity_setting.xml
                 Fixed height required when ListView is inside a ScrollView -->

            <!-- ═══════════════════════════════════════════
                 SHARED GROCERY LIST SECTION
                 Mirrors the ListView + Add/Remove pattern from ListViewPrac activity_setting.xml
                 ═══════════════════════════════════════════ -->

            <TextView
                android:id="@+id/textviewSharedListTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Shared Grocery List"
                android:textColor="#059669"
                android:textSize="16sp"
                android:textStyle="bold"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"/>

            <!-- Add Item button — mirrors button_add_item from ListViewPrac activity_setting.xml -->
            <Button
                android:id="@+id/buttonAddGrocery"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="8dp"
                android:backgroundTint="#059669"
                android:text="＋ Add Grocery Item"
                android:textColor="#FFFFFF"/>

            <!-- ListView for Grocery List — mirrors listview from ListViewPrac activity_setting.xml
                 Fixed height required when ListView is inside a ScrollView -->
            <ListView
                android:id="@+id/listviewGrocery"
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:divider="@null"
                android:dividerHeight="0dp"
                android:clipToPadding="false"/>

            <!-- Bottom spacing -->
            <View
                android:layout_width="match_parent"
                android:layout_height="16dp"/>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation — unchanged from original ShazCart design -->
    <LinearLayout
        android:id="@+id/layoutBottomNav"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:weightSum="4"
        android:background="#F3F4F6"
        android:gravity="center">

        <TextView
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="🏠 Home"
            android:textColor="#059669"
            android:textSize="12sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/navExpenses"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="💰 Expenses"
            android:textColor="#374151"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/navReminders"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="⏰ Reminders"
            android:textColor="#374151"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="👤 Profile"
            android:textColor="#374151"
            android:textSize="12sp"/>

    </LinearLayout>

    <!-- Logout Button — unchanged from original ShazCart design -->
    <Button
        android:id="@+id/buttonLogout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Logout"
        android:textColor="#FFFFFF"
        android:backgroundTint="#DC2626"
        android:layout_margin="16dp"
        android:elevation="2dp"/>

</LinearLayout>
