<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutDashboardPage"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:padding="16dp"
        android:background="#059669">

        <TextView
            android:id="@+id/textviewGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Good afternoon, S 👋"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_alignParentStart="true"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/textviewNotification"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔔 3"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/textviewGroupMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Group Mode — Sunset Boarding House"
            android:textColor="#BBF7D0"
            android:textSize="14sp"
            android:layout_below="@id/textviewGreeting"
            android:layout_marginTop="12dp"/>
    </RelativeLayout>

    <!-- Summary Boxes -->
    <LinearLayout
        android:id="@+id/layoutSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3"
        android:padding="16dp">

        <TextView
            android:id="@+id/textviewTotalItems"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="0 Total Items"
            android:textColor="#374151"
            android:textSize="14sp"
            android:padding="12dp"/>

        <TextView
            android:id="@+id/textviewPendingItems"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="0 Pending"
            android:textColor="#374151"
            android:textSize="14sp"
            android:padding="12dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/textviewTotalSpent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="₱0 Total Spent"
            android:textColor="#374151"
            android:textSize="14sp"
            android:padding="12dp"/>
    </LinearLayout>

    <!-- Split Overview -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:padding="16dp"
        android:background="@drawable/bg_card">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Split Overview"
            android:textColor="#111827"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Tap a housemate to record, edit, or settle payments."
            android:textColor="#6B7280"
            android:textSize="12sp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:weightSum="2">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Needs to pay"
                    android:textColor="#DC2626"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/textviewNeedsToPay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Everyone is settled."
                    android:textColor="#111827"
                    android:textSize="13sp"/>

                <LinearLayout
                    android:id="@+id/layoutNeedsToPayChips"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Should receive"
                    android:textColor="#059669"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/textviewShouldReceive"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Nobody is owed money."
                    android:textColor="#111827"
                    android:textSize="13sp"/>

                <LinearLayout
                    android:id="@+id/layoutShouldReceiveChips"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Scrollable body for RecyclerViews -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HOUSEMATES SECTION -->
            <TextView
                android:id="@+id/textviewHousematesTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Housemates"
                android:textColor="#059669"
                android:textSize="16sp"
                android:textStyle="bold"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"/>

            <Button
                android:id="@+id/buttonAddHousemate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="8dp"
                android:backgroundTint="#059669"
                android:text="＋ Add Housemate"
                android:textColor="#FFFFFF"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerviewHousemates"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"/>

            <!-- SHARED GROCERY LIST SECTION -->
            <TextView
                android:id="@+id/textviewSharedListTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Shared Grocery List"
                android:textColor="#059669"
                android:textSize="16sp"
                android:textStyle="bold"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"/>

            <Button
                android:id="@+id/buttonAddGrocery"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="8dp"
                android:backgroundTint="#059669"
                android:text="＋ Add Grocery Item"
                android:textColor="#FFFFFF"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerviewGrocery"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:clipToPadding="false"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="16dp"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Buttons Menu -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_margin="16dp"
        android:weightSum="2">

        <Button
            android:id="@+id/buttonProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#3B82F6"
            android:text="My Profile"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/buttonLogout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:backgroundTint="#EF4444"
            android:text="Logout"
            android:textColor="#FFFFFF"/>
    </LinearLayout>

</LinearLayout>