<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_bg">

    <LinearLayout
        android:id="@+id/layoutWelcomePage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- Header -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_gradient_green"
                android:padding="20dp"
                android:gravity="center_horizontal">

                <ImageView
                    android:id="@+id/imageviewLogo"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:src="@drawable/shazcartgreenlogo2"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_circle_white"
                    android:contentDescription="ShazCart Logo" />

                <TextView
                    android:id="@+id/textviewTagline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Smart Grocery Coordination"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp" />

                <TextView
                    android:id="@+id/textviewSubTagline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="For boarding houses, dorms, roommates"
                    android:textColor="#BBF7D0"
                    android:textSize="14sp"
                    android:layout_marginTop="6dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Features -->
        <LinearLayout
            android:id="@+id/layoutFeatures"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/textviewFeatureGroupMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👥 Group Mode — Share lists, split costs"
                android:textColor="#374151"
                android:textSize="14sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/textviewFeatureBudget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💰 Budget Tracker — Monitor your spending"
                android:textColor="#374151"
                android:textSize="14sp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/textviewFeatureReminders"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏰ Reminders — Never forget essentials"
                android:textColor="#374151"
                android:textSize="14sp"/>
        </LinearLayout>

        <!-- Hero block -->
        <TextView
            android:id="@+id/textviewHeroPlaceholder"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:gravity="center"
            android:text="(Image Placeholder)"
            android:textColor="#9CA3AF"
            android:textSize="16sp"
            android:background="#F3F4F6"
            android:layout_margin="16dp"
            android:padding="12dp"/>

        <!-- Buttons -->
        <LinearLayout
            android:id="@+id/layoutButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_margin="24dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonGetStarted"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Create Account"
                app:cornerRadius="12dp"
                app:backgroundTint="@color/dashboard_accent"
                android:textColor="@android:color/white"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonLogin"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sign In"
                app:cornerRadius="12dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/dashboard_border"
                android:backgroundTint="@android:color/transparent"
                android:textColor="@color/dashboard_primary" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
