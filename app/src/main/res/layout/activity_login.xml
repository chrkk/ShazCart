<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layoutLoginPage"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Header -->
    <RelativeLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@drawable/bg_gradient_green"
        android:padding="16dp">

        <!-- Back button -->
        <LinearLayout
            android:id="@+id/layoutBackButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_alignParentTop="true"
            android:layout_alignParentStart="true">

            <!-- Fallback arrow -->
            <ImageView
                android:id="@+id/imageviewBackIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_revert"
                android:tint="#FFFFFF" />

            <TextView
                android:id="@+id/textviewBackLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Back"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

        <!-- Big circular logo -->
        <ImageView
            android:id="@+id/imageviewLogo"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/shazcartgreenlogo2"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="48dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_circle_white"
            android:contentDescription="ShazCart Logo"/>

        <!-- Welcome text -->
        <TextView
            android:id="@+id/textviewWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome back!"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_below="@id/imageviewLogo"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/textviewSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sign in to your account"
            android:textColor="#BBF7D0"
            android:textSize="14sp"
            android:layout_below="@id/textviewWelcome"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="6dp"/>
    </RelativeLayout>

    <!-- Form Card -->
    <LinearLayout
        android:id="@+id/layoutFormCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:layout_marginTop="-40dp"
        android:background="#FFFFFF"
        android:elevation="4dp">
        <!-- Error message -->
        <TextView
            android:id="@+id/textviewError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FEE2E2"
            android:textColor="#DC2626"
            android:padding="12dp"
            android:visibility="gone"
            android:textSize="13sp"/>
        <!-- Email -->
        <TextView
            android:id="@+id/textviewEmailLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email Address"
            android:textColor="#374151"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>
        <EditText
            android:id="@+id/edittextEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="you@example.com"
            android:inputType="textEmailAddress"
            android:padding="12dp"
            android:background="@drawable/bg_input"
            android:textSize="14sp"
            android:textColor="#1F2937"
            android:textColorHint="#9CA3AF"/>
        <!-- Password -->
        <TextView
            android:id="@+id/textviewPasswordLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Password"
            android:textColor="#374151"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>
        <EditText
            android:id="@+id/edittextPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter your password"
            android:inputType="textPassword"
            android:padding="12dp"
            android:background="@drawable/bg_input"
            android:textSize="14sp"
            android:textColor="#1F2937"
            android:textColorHint="#9CA3AF"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Launch mode"
            android:textColor="#374151"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <RadioGroup
            android:id="@+id/radioGroupMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <RadioButton
                android:id="@+id/radioGroup"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Group"
                android:textColor="#374151"
                android:checked="true"/>

            <RadioButton
                android:id="@+id/radioSolo"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Solo"
                android:textColor="#374151"/>
        </RadioGroup>
        <!-- Sign In -->
        <Button
            android:id="@+id/buttonSignIn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sign In"
            android:textColor="#FFFFFF"
            android:backgroundTint="#059669"
            android:layout_marginTop="24dp"/>
        <!-- Sign Up -->
        <TextView
            android:id="@+id/textviewSignUp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Don't have an account? Sign Up"
            android:textColor="#059669"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginTop="12dp"/>
    </LinearLayout>
    <!-- Demo hint -->
    <TextView
        android:id="@+id/textviewDemoHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
            android:text="💡 Choose Solo or Group before signing in"
        android:textColor="#047857"
        android:textSize="12sp"
        android:gravity="center"
        android:background="#ECFDF5"
        android:padding="12dp"
        android:layout_margin="16dp"/>
</LinearLayout>
